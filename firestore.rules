rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // 도우미 함수 (Helper Functions)
    // ===============================================================
    
    // 인증 여부 확인
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // 문서 소유자 여부 확인 (uid 필드 기준)
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 관리자 여부 확인 (이메일 및 이메일 인증 여부 기준)
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "chaeyoon1732@gmail.com" && request.auth.token.email_verified == true);
    }

    // ===============================================================
    // 데이터 유효성 검사 (Validation Functions)
    // ===============================================================

    // 페르소나 데이터 유효성 검사
    function isValidPersona(data) {
      return data.name is string && data.name.size() > 0 &&
             data.role is string &&
             data.department in ["영업", "서비스"] &&
             data.difficulty in ["상", "중", "하"];
    }

    // 시나리오 데이터 유효성 검사
    function isValidScenario(data) {
      return data.title is string && data.title.size() > 0 &&
             data.category is string &&
             data.goal is string;
    }

    // 시뮬레이션 결과 유효성 검사
    function isValidSimulationResult(data) {
      return data.userId == request.auth.uid &&
             data.score is number && data.score >= 0 && data.score <= 100 &&
             data.timestamp is number;
    }

    // ===============================================================
    // 컬렉션별 규칙 (Collection Rules)
    // ===============================================================

    // 페르소나 목록: 인증된 사용자는 읽기 가능, 관리자만 쓰기 가능
    match /personas/{personaId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidPersona(request.resource.data);
    }

    // 시나리오 목록: 인증된 사용자는 읽기 가능, 관리자만 쓰기 가능
    match /scenarios/{scenarioId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidScenario(request.resource.data);
    }

    // 시뮬레이션 결과: 소유자만 읽기/쓰기 가능, 관리자는 모든 결과 읽기 가능
    match /2026_simulation/{simulationId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && isValidSimulationResult(request.resource.data);
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }
  }
}
